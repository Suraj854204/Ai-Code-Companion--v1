# ===== AI Code Companion Microservices + Neon PostgreSQL + Prisma =====
# Copy this file to .env at project root and also use the same values in Docker Compose.

# Neon PostgreSQL connection string
# Get from Neon Console > Project > Dashboard > Connection string > pooled/unpooled URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# JWT secret: generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret"
JWT_EXPIRES_IN="12h"

# AES key for encrypting GitHub token and Claude API key
# Generate with: openssl rand -hex 32
ENCRYPT_KEY="your-32-byte-encryption-key"

# Frontend origin
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Service ports
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
GITHUB_SERVICE_PORT=4002
AI_SERVICE_PORT=4003
SCANNER_SERVICE_PORT=4004
REPORT_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006

# Internal service URLs for Docker network
AUTH_SERVICE_URL="http://localhost:4001"
GITHUB_SERVICE_URL="http://localhost:4002"
AI_SERVICE_URL="http://localhost:4003"
SCANNER_SERVICE_URL="http://localhost:4004"
REPORT_SERVICE_URL="http://localhost:4005"
NOTIFICATION_SERVICE_URL="http://localhost:4006"
# Redis cache
REDIS_URL="redis://redis:6379"

# GEMINI AI model name
GEMINI_MODEL="gemini-2.5-flash"

# GEMINI API key (from GOOgle api)
GEMINI_API_KEY="your-gemini-api-key"
# Email provider optional, used by notification-service
RESEND_API_KEY=""
FROM_EMAIL="noreply@example.com"